RewriteEngine On

# Block direct access to /views/tools/*.php and /views/content/*.php
RewriteCond %{THE_REQUEST} /views/(tools|content)/([^\s?]+\.php) [NC]
RewriteRule ^ - [F,L]

# First - Route all normal pages (contact, about, privacy, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(about|contact|privacy|disclaimer)/?$ views/$1.php [L,NC]

# Text Comparison Cluster
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(compare-two-text-files-online|compare-text-line-by-line|compare-json-files-online|compare-xml-files-online|compare-html-files-online|compare-css-files-online|compare-code-files-online|online-text-diff-tool|text-difference-checker|compare-text-documents)/?$ views/tools/text-comparison.php [L,NC]

# Second - Route tool pages (pdf-to-csv, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/?$ views/tools/$1.php [L]

# Fallback - Remove .php extension for other pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/views/tools/ [NC]
RewriteRule ^([^/]+)/?$ $1.php [L]

#Redirect non-www → www
RewriteEngine On
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]


RewriteEngine On
# Redirect index.php / index.html to root
RewriteCond %{THE_REQUEST} \s/+index\.(php|html) [NC]
RewriteRule ^index\.(php|html)$ https://www.wordscompare.com/ [R=301,L]